    "fastify": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "pino": "^9.0.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.0.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
