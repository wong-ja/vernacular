{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@vernacular/api/*": ["./apps/api/src/*"],
      "@vernacular/shared": ["./packages/shared/src/index.ts"],
      "@vernacular/glossary": ["./packages/glossary/src/index.ts"]
    }
  },
  "include": [
    "packages/shared/src/**/*.ts",
    "packages/glossary/src/**/*.ts",
    "apps/web/components/**/*.tsx",
    "apps/api/src/**/*.ts"
  ]
}
